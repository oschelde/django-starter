msgstr "E-mailadresse %(deleted_email)s er blevet fjernet fra din konto."

#: templates/account/email/email_deleted_subject.txt:3
msgid "Email Removed"
msgstr "E-mail fjernet"

#: templates/account/email/login_code_message.txt:5
msgid ""
"Your sign-in code is listed below. Please enter it in your open browser "
"window."
msgstr ""
"Din loginkode er angivet nedenfor. Indtast det venligst i dit åbne "
"browservindue."

